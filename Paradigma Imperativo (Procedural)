# Lista de funcionários
funcionarios = [
    {"nome": "Ana", "cargo": "Gerente", "salario": 6000},
    {"nome": "João", "cargo": "Vendedor", "salario": 3000},
    {"nome": "Carlos", "cargo": "Analista", "salario": 4500}
]

valor_x = 4000
total_bonus = 0

# Percorre cada funcionário da lista
for funcionario in funcionarios:

    # Verifica quem ganha acima do valor definido
    if funcionario["salario"] > valor_x:

        # Calcula 10% de bônus
        bonus = funcionario["salario"] * 0.10

        print(funcionario["nome"], "recebe bônus de", bonus)

        # Soma no total de bônus
        total_bonus += bonus

print("Total gasto com bônus:", total_bonus)

