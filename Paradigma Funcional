from functools import reduce

funcionarios = [
    {"nome": "Ana", "cargo": "Gerente", "salario": 6000},
    {"nome": "João", "cargo": "Vendedor", "salario": 3000},
    {"nome": "Carlos", "cargo": "Analista", "salario": 4500}
]

valor_x = 4000

# Filtra funcionários com salário maior que X
filtrados = list(filter(lambda f: f["salario"] > valor_x, funcionarios))

# Cria nova lista com nome e bônus
bonus_funcionarios = list(map(
    lambda f: {
        "nome": f["nome"],
        "bonus": f["salario"] * 0.10
    },
    filtrados
))

# Mostra bônus de cada funcionário
for f in bonus_funcionarios:
    print(f["nome"], "recebe bônus de", f["bonus"])

# Soma total de bônus
total = reduce(lambda acc, f: acc + f["bonus"], bonus_funcionarios, 0)

print("Total gasto com bônus:", total)
